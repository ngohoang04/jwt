<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Edit User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5">
        <h2>Edit User</h2>
        <form action="/users/update-user" method="POST">
            <!-- Gửi ID ẩn đi để biết user nào cần update -->
            <input type="hidden" name="id" value="<%= user.id %>">

            <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input type="email" name="email" class="form-control" id="email" value="<%= user.email %>" required>
            </div>

            <div class="mb-3">
                <label for="UserName" class="form-label">UserName</label>
                <input type="text" name="UserName" class="form-control" id="UserName" value="<%= user.user %>" required>
            </div>

            <div class="mb-3">
                <label for="Pass" class="form-label">Password (để nguyên nếu không đổi)</label>
                <input type="password" name="Pass" class="form-control" id="Pass">
            </div>

            <button type="submit" class="btn btn-success">Update</button>
            <a href="/" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</body>

</html>